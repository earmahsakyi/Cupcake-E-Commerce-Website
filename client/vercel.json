{
  "rewrites": [
    { 
      "source": "/api/:path*", 
      "destination": "https://cupcake-e-commerce-website-production.up.railway.app/api/:path*" 
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/cake/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}